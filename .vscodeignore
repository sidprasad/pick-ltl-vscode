.vscode/**
.vscode-test/**
.github/**
src/**
util/**
.gitignore
.yarnrc
AGENTS.md
vsc-extension-quickstart.md

# Python backend is vendored and SHIPS in the .vsix (python/**), but never its
# caches or the standalone test artifacts.
python/**/__pycache__/**
python/**/*.pyc
**/.pytest_cache/**
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/.vscode-test.*
*.vsix

# Exclude dev-only dependencies. Runtime deps (@sidprasad/ltl-ts and its
# antlr4ng) are intentionally kept so the engine ships in the .vsix.
node_modules/@types/**
node_modules/@vscode/**
node_modules/@eslint/**
node_modules/@typescript-eslint/**
node_modules/eslint/**
node_modules/mocha/**
node_modules/typescript/**
node_modules/typescript-eslint/**
node_modules/ovsx/**
