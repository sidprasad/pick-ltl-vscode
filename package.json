{
  "name": "pick-ltl",
  "displayName": "PICK: LTL Builder",
  "description": "Generate candidate LTL formulas from an LLM, then refine them by classifying distinguishing traces.",
  "publisher": "SiddharthaPrasad",
  "icon": "images/icon.png",
  "license": "MIT",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidprasad/pick-ltl-vscode"
  },
  "bugs": {
    "url": "https://github.com/sidprasad/pick-ltl-vscode/issues"
  },
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20.18.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ltl",
    "linear temporal logic",
    "temporal logic",
    "llm",
    "human in the loop",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pick-ltl-explorer",
          "title": "PICK LTL Builder",
          "icon": "images/activitybar.svg"
        }
      ]
    },
    "views": {
      "pick-ltl-explorer": [
        {
          "type": "webview",
          "id": "pick-ltl.pickView",
          "name": "LTL Builder",
          "icon": "images/activitybar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "pick-ltl.reportIssue",
        "title": "Report an Issue",
        "category": "PICK LTL Builder"
      },
      {
        "command": "pick-ltl.resetSurveyState",
        "title": "Clear Local Storage",
        "category": "PICK LTL Builder"
      },
      {
        "command": "pick-ltl.restartBackend",
        "title": "Set Up / Restart Backend",
        "category": "PICK LTL Builder"
      }
    ],
    "keybindings": [
      {
        "command": "pick-ltl.reportIssue",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ],
    "configuration": {
      "title": "PICK LTL Builder",
      "properties": {
        "pick-ltl.surveyPromptEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the survey prompt after using PICK multiple times"
        },
        "pick-ltl.showIssueReportModal": {
          "type": "boolean",
          "default": true,
          "description": "Show modal dialog when reporting an issue to remind user to paste clipboard content"
        },
        "pick-ltl.maxPairsWithoutProgress": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "How many consecutive trace pairs that fail to eliminate any candidate to tolerate before PICK stops asking and surfaces the best match so far."
        },
        "pick-ltl.backend.pythonPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to a Python interpreter for the PICK LTL backend sidecar. The interpreter's environment must have `spot` installed (`conda install -c conda-forge spot`). Leave empty to auto-detect — or auto-create via **PICK LTL: Set Up / Restart Backend** — a conda environment named `pick-ltl`."
        },
        "pick-ltl.backend.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the Python backend sidecar automatically when the extension activates."
        },
        "pick-ltl.backend.port": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "Localhost port for the backend sidecar. 0 selects a free port automatically."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rm -rf out",
    "compile": "npm run clean && tsc -p ./",
    "package:vsix": "npx @vscode/vsce package",
    "publish:vsce": "npx @vscode/vsce publish",
    "publish:ovsx": "npx ovsx publish",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run clean && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test --timeout 8000"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "mocha": "^10.7.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^0.10.1"
  },
  "dependencies": {}
}
